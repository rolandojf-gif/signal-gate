# Which backend feeds the dashboard.
#   mock     -> local TypeScript data in src/data/mockBriefings.ts (no keys)
#   netlify  -> /.netlify/functions/briefings  (ready; serves a mock payload)
#   supabase -> Supabase table                 (stub: implement loadSupabase)
# Local `npm run dev` defaults to mock; the deployed site sets netlify in netlify.toml.
VITE_DATA_SOURCE=mock

# --- Server-side only (the Netlify Function) — NOT exposed to the browser ---
# Google Gemini API key from https://aistudio.google.com  (free tier works).
# When set, /.netlify/functions/briefings asks Gemini to generate the current
# briefing. When absent, the function serves the bundled mock.
# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL=gemini-2.5-flash-lite   # default; fits Netlify's 10s sync limit.
# Note: each Gemini model has its own free-tier quota bucket; switch models here
# if one returns 429 (quota exceeded).

# Phase 2 — not read yet, placeholders for when the loaders are wired:
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
