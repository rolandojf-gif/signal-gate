# Which backend feeds the dashboard. Phase 1 ships with 'mock'.
#   mock     -> local TypeScript data in src/data/mockBriefings.ts (no keys)
#   netlify  -> /.netlify/functions/briefings  (implement loadNetlify in src/lib/briefingSource.ts)
#   supabase -> Supabase table                 (implement loadSupabase in src/lib/briefingSource.ts)
VITE_DATA_SOURCE=mock

